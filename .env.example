# Neon (provisioned via Vercel Marketplace → Storage → Neon)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Clerk (provisioned via Vercel Marketplace → Auth → Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routing (safe defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Webhook signing secrets
CALENDLY_SIGNING_KEY=
TALLY_SIGNING_SECRET=
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Vercel Blob (provision via Vercel Marketplace → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Anthropic API (for Claude-assisted resource authoring)
ANTHROPIC_API_KEY=sk-ant-...

# Zoom server-to-server OAuth (for meeting recording pipeline)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_COACH_USER_ID=
